{
  "name": "fittrack-e2e",
  "version": "1.0.0",
  "description": "Playwright E2E tests for FitTrack",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui",
    "test:testrunner" : "playwright test --ui",
    "test:headed": "playwright test --project=ui --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
